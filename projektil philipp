public class projektil extends Actor
{
    public void act()
    {
        zerstoere();
        fliege();
        explosion();
    }
    private Actor schuetze; 
    
    
    /**
     * Act - do whatever the projektil wants to do. This method is called whenever
     * the 'Act' or 'Run' button gets pressed in the environment.
     */
    public boolean tankyVorhanden()
    {
        if (getOneIntersectingObject(tanky.class)!=null)
        {
            return true;
        }
        return false;
    }
    public void zerstoere()
    {
        if (tankyVorhanden())
        {
            removeTouching(tanky.class);
        }
    }
    public boolean fadenKreuzVorhanden()
    {
        if (getOneIntersectingObject(fadenKreuz.class)!=null)
        {
            return true;
        }
        return false;
    }
    public void fliege()
    {
        // 1. Finde das fadenkreuz
        Actor ziel = (fadenKreuz) getWorld().getObjects(fadenKreuz.class).get(0);
        
        if (ziel != null) {
            // 2. Drehe dich zum Ziel
            turnTowards(ziel.getX(), ziel.getY());
        int speed = 3;
         move(speed);
        }
         else if (isTouching(wall.class)) 
         { 
         turn(180);
         }
    }
    public void explosion()
    {
        if (isTouching(wall.class))
        {
            getWorld().removeObject(this);
        }
    }
    public void getroffen()
    {
       Actor getroffen = getOneIntersectingObject(tanky.class);
       if(getroffen != null && getroffen !=schuetze)
       {
           getWorld().removeObject(getroffen);
           getWorld().removeObject(this);
       }
    }
}
